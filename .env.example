# temaki configuration — copy to `.env` and adjust. `.env` is gitignored; never commit real values.

# --- Marshaller: a LOCAL OpenAI-compatible endpoint (LM Studio, Ollama, llama.cpp, ...) ---
# Pane content is only ever sent here. Never point this at a remote/cloud model.
# LM Studio default:  http://localhost:1234/v1
# Ollama  default:    http://localhost:11434/v1
TEMAKI_MARSHALLER_BASE_URL=http://localhost:1234/v1
TEMAKI_MARSHALLER_MODEL=local-model
# Optional — most local servers ignore the key. Leave unset if not required.
# TEMAKI_MARSHALLER_KEY=

# --- Session driver (M2+) ---
# The interactive terminal agent to wrap. Use a free local REPL while developing.
TEMAKI_AGENT_CMD=bc
# tmux session name.
TEMAKI_SESSION=temaki

# --- Server (M3+) ---
# Loopback bind only. The bearer token clients must present as `Authorization: Bearer <token>`.
TEMAKI_SERVER_HOST=127.0.0.1
TEMAKI_SERVER_PORT=8765
# Generate your own, e.g.  openssl rand -hex 32
TEMAKI_API_TOKEN=change-me-local-only
